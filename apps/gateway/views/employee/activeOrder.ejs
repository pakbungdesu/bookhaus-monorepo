<!DOCTYPE html>
<html lang="en">
<head>
    <title>Employee Home</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
</head>
<body class="bg-gray-50 antialiased">
    <%- include('../partials/navbar') %>

    <main class="max-w-6xl mx-auto py-12 px-6">
        <h1 class="text-3xl font-bold text-gray-900 mb-8 flex items-center gap-3">
            Active Orders <span class="text-xl grayscale opacity-70">📦</span>
        </h1>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 font-black uppercase text-xs text-gray-400">Order ID</th>
                        <th class="px-6 py-4 font-black uppercase text-xs text-gray-400">Date</th>
                        <th class="px-6 py-4 font-black uppercase text-xs text-gray-400">Status</th>
                        <th class="px-6 py-4 font-black uppercase text-xs text-gray-400 text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% orders.forEach(ord => { %>
                    <tr class="hover:bg-gray-50/50 transition">
                        <td class="px-6 py-4">
                            <button onclick="showDetails('<%= ord.orderId %>')" 
                                class="font-bold text-blue-600 hover:underline">
                                #<%= ord.orderId %>
                            </button>
                        </td>
                        <td class="px-6 py-4 text-gray-500"><%= new Date(ord.orderDate).toLocaleString() %></td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 rounded-full text-xs font-black uppercase 
                                <%= ord.status === 'Paid' ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700' %>">
                                <%= ord.status %>
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <% if (ord.status === 'Paid') { %>
                                <button onclick="updateStatus('<%= ord.orderId %>', 'Shipped')" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-bold text-sm hover:bg-blue-700 transition">Ship</button>
                            <% } else if (ord.status === 'Shipped') { %>
                                <button onclick="updateStatus('<%= ord.orderId %>', 'Completed')" class="px-4 py-2 bg-green-600 text-white rounded-lg font-bold text-sm hover:bg-green-700 transition">Complete</button>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="detailModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl max-w-2xl w-full p-8 shadow-2xl relative">
            <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-black text-xl">✕</button>
            
            <h2 id="modalTitle" class="text-2xl font-black italic mb-6">Order Details</h2>
            <h3 id="modalCustomer" class="text-xl font-bold mb-6">Customer ID</h3>
            
            <div id="modalContent" class="space-y-4 max-h-[60vh] overflow-y-auto pr-2">
                </div>
            
            <div class="mt-8 pt-6 border-t border-gray-100 flex justify-between items-center">
                <span class="text-gray-400 font-bold uppercase text-xs tracking-widest">Grand Total</span>
                <span id="modalTotal" class="text-3xl font-black text-blue-600"></span>
            </div>
        </div>
    </div>
    <script>
        async function updateStatus(id, status) {
            const res = await fetch(`/order/update-status/${id}`, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ status })
            });
            if (res.ok) window.location.reload();
        }

        async function showDetails(id) {
            try {
                console.log(`Fetching details for order ID: ${id}`);
                const res = await fetch(`/order/${id}`); 
                const order = await res.json(); 
                
                const details = order.orderDetails || [];
                document.getElementById('modalTitle').innerText = `Items for Order #${id}`;
                document.getElementById('modalCustomer').innerText = `Customer ID: ${order.customerId}`;
                
                const total = order.orderTotal || 0; 
                document.getElementById('modalTotal').innerText = `$${total.toLocaleString(undefined, { minimumFractionDigits: 2 })}`;
                
                const content = details.map(item => {
                    // Safe price extraction
                    const rawPrice = parseFloat(item.book?.price || item.unitPrice || 0);
                    const itemTotal = (parseInt(item.quantity) || 0) * rawPrice;

                    return `
                        <div class="flex justify-between items-center border-b border-gray-50 pb-4">
                            <div>
                                <p class="font-bold text-gray-800 text-lg">${item.book?.title || 'Unknown Book'}</p>
                                <p class="text-sm text-gray-400 font-medium">Qty: ${item.quantity} × $${rawPrice.toFixed(2)}</p>
                            </div>
                            <span class="font-black text-gray-700">$${itemTotal.toLocaleString(undefined, { minimumFractionDigits: 2 })}</span>
                        </div>
                    `;
                }).join('');
                
                document.getElementById('modalContent').innerHTML = content || '<p class="text-gray-400 text-center">No items found.</p>';
                document.getElementById('detailModal').classList.remove('hidden');

            } catch (err) {
                console.error("Error in showDetails:", err);
                alert("Failed to display order details.");
            }
        }

        function closeModal() {
            document.getElementById('detailModal').classList.add('hidden');
        }

        window.onclick = function(event) {
            const modal = document.getElementById('detailModal');
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>