<!DOCTYPE html>
<html lang="en">
<head>
    <title>Employee Home</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
</head>
<body class="bg-gray-50 antialiased">
    <%- include('../partials/navbar') %>
  
    <div class="w-full overflow-hidden mb-10">
        <img src="/images/bookhaus.png" alt="Hero Banner" 
            class="w-full h-64 md:h-[400px] object-cover object-center">
    </div>
    <main class="max-w-7xl mx-auto px-6 py-12 mt-10">
        <div class="text-center space-y-4 mb-16">
            <h1 class="text-5xl font-black tracking-tight text-gray-900">
                <span class="text-blue-600">Book & People</span> Management
            </h1>
            <p class="text-xl text-gray-500 italic">Smart Tools for Better Bookselling 💡</p>
        </div>

        <div class="max-w-4xl mx-auto space-y-8">
            <% const features = [
                { icon: 'pi-users', title: 'Smart Team', desc: 'Curators of imagination who bridge the gap between data and the human heart.' },
                { icon: 'pi-cog', title: 'Smart Tool', desc: 'Frictionless systems that simplify the complex so you can focus on the story.' },
                { icon: 'pi-bolt', title: 'Smart Vibe', desc: 'A modern, soulful atmosphere where efficiency meets pure inspiration.' }
            ] %>

            <% features.forEach(f => { %>
                <div class="flex items-center gap-8 bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition">
                    <div class="flex items-center gap-4 w-1/3 justify-end border-r pr-8 border-gray-100">
                        <i class="pi <%= f.icon %> text-3xl text-blue-500"></i>
                        <span class="text-2xl font-bold text-gray-800"><%= f.title %></span>
                    </div>
                    <p class="text-lg text-gray-600 w-2/3"><%= f.desc %></p>
                </div>
            <% }) %>
        </div>

        <div class="mt-20 flex flex-col items-center">
            <img src="/images/whywe1.webp" class="max-w-md mb-10">
            <pre class="text-center font-sans text-xl text-gray-600 leading-relaxed">
At Bookhaus, we believe that when the systems are simple,
you have more time for what truly matters:
connecting the right stories with the right readers.
            </pre>
        </div>
    </main>
</body>
</html>