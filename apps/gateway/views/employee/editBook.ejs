<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Books | BookHaus</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
</head>
<body class="bg-gray-50 font-sans antialiased">
    <script>
        let debounceTimer;

        async function performSearch() {
            clearTimeout(debounceTimer);
            
            debounceTimer = setTimeout(async () => {
                const title = document.getElementById('search-title').value;
                const author = document.getElementById('search-author').value;
                const genre = document.getElementById('search-genre').value;
                const gallery = document.getElementById('book-gallery');

                // Using URLSearchParams to handle encoding correctly
                const params = new URLSearchParams({ title, author, genre });

                try {
                    const response = await fetch(`/book/search?${params.toString()}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                
                const html = await response.text();
                gallery.innerHTML = html;
                } catch (error) {
                    console.error('Search failed:', error);
                }
            }, 300);
        }

        // Prevent form from reloading page if "Enter" is pressed
        function handleForm(event) {
            event.preventDefault();
            performSearch();
        }

        async function changePage(pageNum) {
            const title = document.getElementById('search-title').value;
            const author = document.getElementById('search-author').value;
            const genre = document.getElementById('search-genre').value;
            const gallery = document.getElementById('book-gallery');

            // Add the page number to the search params
            const params = new URLSearchParams({ 
                page: pageNum, 
                title, 
                author, 
                genre 
            });

            try {
                const response = await fetch(`/book/search?${params.toString()}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const html = await response.text();
                gallery.innerHTML = html;
                
                // Optional: Scroll back to the top of the gallery so the user sees the new books
                gallery.scrollIntoView({ behavior: 'smooth' });
            } catch (error) {
                console.error('Pagination failed:', error);
            }
        }
    </script>

    <%- include('../partials/navbar') %>

    <main class="max-w-6xl mx-auto px-4 py-12 min-h-[70vh]">                
        <h1 class="text-3xl font-bold text-gray-900 mb-8 flex items-center gap-3">
            Find a Book 📚
        </h1>
        <form onsubmit="handleForm(event)">
            <div class="p-8 bg-white rounded-2xl shadow-sm border border-gray-100">
                <div class="mt-6 flex flex-wrap gap-4">
                    <input type="text" id="search-title" placeholder="Search by title..." 
                        oninput="performSearch()"
                        class="flex-1 min-w-[200px] px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition">
                    
                    <input type="text" id="search-author" placeholder="Search by author..." 
                        oninput="performSearch()"
                        class="flex-1 min-w-[200px] px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none transition">

                    <select id="search-genre" onchange="performSearch()" class="flex-0.5 min-w-[150px] px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-600 outline-none bg-white">
                        <option value="">All Genres</option>
                        <% ["Classic", "Science Fiction", "Fiction", "Technology", "Young Adult", "Fantasy", "Horror", "Thriller", "Non-Fiction", "Mystery", "Children", "Philosophy"].forEach(g => { %>
                            <option value="<%= g %>"><%= g %></option>
                        <% }) %>
                    </select>
                    
                    <button type="button" onclick="performSearch()"
                    class="bg-blue-600 text-white px-8 py-2.5 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-100">
                        Search
                    </button>
                </div>                 
            </div>
        </form>

        <div class="mt-8 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div id="book-gallery" class="divide-y divide-gray-200">
                 <%- include('../partials/bookCards') %>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>