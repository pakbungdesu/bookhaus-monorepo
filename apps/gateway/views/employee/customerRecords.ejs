<!DOCTYPE html>
<html lang="en">
<head>
    <title>Customer Records | Bookhaus</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 antialiased">
    <%- include('../partials/navbar') %>

    <main class="max-w-6xl mx-auto py-12 px-6">
        <h1 class="text-3xl font-bold text-gray-900 mb-8 flex items-center gap-3">
            Customer Management 📋
        </h1>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b border-gray-100 text-xs uppercase text-gray-400 font-black">
                    <tr>
                        <th class="px-6 py-4 w-16">ID</th>
                        <th class="px-6 py-4">Name</th>
                        <th class="px-6 py-4">Email</th>
                        <th class="px-6 py-4">Orders</th>
                        <th class="px-6 py-4">Phone</th>
                        <th class="px-6 py-4">Address</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% if (customers.length === 0) { %>
                        <tr>
                            <td colspan="6" class="px-6 py-10 text-center text-gray-400 italic">
                                No customer records found
                            </td>
                        </tr>
                    <% } %>

                    <% customers.forEach(cus => { %>
                    <tr class="hover:bg-gray-50/50 transition">
                        <td class="px-6 py-4 font-mono text-gray-400 text-sm">
                            #<%= cus.id %>
                        </td>
                        <td class="px-6 py-4">
                            <span class="font-bold text-gray-700">
                                <%= cus.person?.firstname %> <%= cus.person?.lastname %>
                            </span>
                        </td>
                        <td class="px-6 py-4 text-blue-600 font-medium text-sm">
                            <%= cus.person?.email %>
                        </td>
                        <td class="px-6 py-4">
                            <a href="/order/history?id=<%= cus.id %>" 
                            class="px-3 py-1 rounded-full text-xs font-black transition-all duration-300
                            <%= cus.orderCount > 0 
                                ? 'bg-blue-100 text-blue-700 hover:bg-blue-600 hover:text-white' 
                                : 'bg-gray-100 text-gray-400 hover:bg-gray-200' %>">
                                <i class="pi pi-shopping-bag mr-1 text-[10px]"></i>
                                <%= cus.orderCount %> <%= cus.orderCount === 1 ? 'Order' : 'Orders' %>
                            </a>
                        </td>
                        <td class="px-6 py-4 text-gray-500 text-sm">
                            <%= cus.person?.phone || 'N/A' %>
                        </td>
                        <td class="px-6 py-4 text-gray-500 text-sm max-w-xs truncate">
                            <%= cus.person?.address %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>