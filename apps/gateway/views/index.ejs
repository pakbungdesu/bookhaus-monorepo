<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sign In | BookHaus</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
</head>
<body class="bg-gray-50 font-sans antialiased">
    <%- include('./partials/navbar') %>

    <main class="min-h-[80vh] flex items-center justify-center p-6">
        <div class="bg-white p-12 rounded-3xl shadow-2xl shadow-gray-200 border border-gray-100 max-w-2xl w-full text-center">
            
            <div class="py-6">
                <img src="/images/logo.png" alt="Bookhaus" class="max-w-[15%] mx-auto">
            </div>

            <h2 class="text-3xl font-bold text-gray-900 mb-4">
                Welcome to Bookhaus Bookstore
            </h2>
            
            <p class="text-gray-500 text-lg mb-10 leading-relaxed">
                Your portal for the finest collection of literature and professional management.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/auth/loginCus" class="inline-flex items-center justify-center gap-2 bg-black text-white px-8 py-4 rounded-lg font-semibold hover:bg-gray-800 transition duration-300">
                    <i class="pi pi-user"></i> Customer Login
                </a>
                
                <a href="/auth/loginEmp" class="inline-flex items-center justify-center gap-2 bg-gray-100 text-gray-700 px-8 py-4 rounded-lg font-semibold border border-gray-200 hover:bg-gray-200 transition duration-300">
                    <i class="pi pi-briefcase"></i> Employee Portal
                </a>
            </div>
        </div>
    </main>
    <%- include('./partials/footer') %>
</body>
</html>