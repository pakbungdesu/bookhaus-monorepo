<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - Bookhaus</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
</head>
<body class="bg-gray-50 font-sans antialiased text-gray-900">

    <%- include('../partials/navbar') %>

    <div class="max-w-3xl mx-auto px-4 py-12">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
            
            <div class="bg-gray-50 border-b border-gray-200 px-8 py-4">
                <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                    <i class="pi pi-user-edit text-blue-600"></i> Edit Account Details
                </h2>
            </div>

            <div class="p-8">
                <form id="editForm" action="/customer/update" method="POST" class="space-y-6">
                    
                    <input type="hidden" name="id" value="<%= customer.id %>">

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
                        
                        <label for="firstname" class="md:text-left px-4 font-bold text-gray-700 text-sm">First Name:</label>
                        <div class="md:col-span-2">
                            <input type="text" id="firstname" name="firstname" 
                                   value="<%= customer.person?.firstname %>" required
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        </div>

                        <label for="lastname" class="md:text-left px-4 font-bold text-gray-700 text-sm">Last Name:</label>
                        <div class="md:col-span-2">
                            <input type="text" id="lastname" name="lastname" 
                                   value="<%= customer.person?.lastname %>" required
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        </div>

                        <label for="birthDate" class="md:text-left px-4 font-bold text-gray-700 text-sm">Birthday:</label>
                        <div class="md:col-span-2">
                            <input type="date" id="birthDate" name="birthdate" 
                                   value="<%= customer.person?.birthdate ? new Date(customer.person.birthdate).toISOString().split('T')[0] : '' %>"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        </div>

                        <label class="md:text-left px-4 font-bold text-gray-700 text-sm">Gender:</label>
                        <div class="md:col-span-2 flex gap-6">
                            <% ['Female', 'Male', 'Other'].forEach(gender => { %>
                                <label class="flex items-center gap-2 cursor-pointer text-sm">
                                    <input type="radio" name="gender" value="<%= gender %>" 
                                           class="w-4 h-4 accent-blue-600"
                                           <%= customer.person?.gender === gender ? 'checked' : '' %>>
                                    <%= gender %>
                                </label>
                            <% }) %>
                        </div>

                        <label for="email" class="md:text-left px-4 font-bold text-gray-700 text-sm">Email:</label>
                        <div class="md:col-span-2">
                            <input type="email" id="email" name="email" 
                                   value="<%= customer.person?.email %>" required
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        </div>

                        <label for="phone" class="md:text-left px-4 font-bold text-gray-700 text-sm">Phone:</label>
                        <div class="md:col-span-2">
                            <input type="text" id="phone" name="phone" 
                                   value="<%= customer.person?.phone %>"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        </div>

                        <label for="address" class="md:text-left px-4 font-bold text-gray-700 text-sm">Address:</label>
                        <div class="md:col-span-2">
                            <input type="text" id="address" name="address" 
                                   value="<%= customer.person?.address %>" required
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                        </div>
                    </div>

                    <div class="flex justify-center md:justify-end gap-4 pt-8 border-t border-gray-100">
                        <button type="submit" class="inline-flex items-center gap-2 px-8 py-2.5 bg-green-600 text-white font-bold rounded-lg hover:bg-green-700 transition shadow-md cursor-pointer">
                            <i class="pi pi-check"></i> Save Changes
                        </button>
                        
                        <a href="/customer/profile" class="inline-flex items-center gap-2 px-8 py-2.5 bg-gray-500 text-white font-bold rounded-lg hover:bg-gray-600 transition shadow-md">
                            <i class="pi pi-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>