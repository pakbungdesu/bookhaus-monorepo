<!DOCTYPE html>
<html lang="en">
<html>
<head>
    <meta charset="UTF-8">
    <title>Home | BookHaus</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/primeicons/primeicons.css">
</head>
<body class="bg-white font-sans antialiased">
    <%- include('../partials/navbar') %>

    <div class="w-full overflow-hidden">
        <img src="/images/bookhaus.png" alt="Hero Banner" 
            class="w-full h-64 md:h-[400px] object-cover object-center">
    </div>

    <main class="max-w-5xl mx-auto px-5 py-16">
        <div class="py-10 mt-25">
            <h1 class="text-5xl text-gray-900 text-center font-bold mt-10">Lose Yourself in a Story</h1>
            <h1 class="text-5xl text-gray-900 text-center font-bold mt-4 py-2">
                Find Yourself in <span class="italic text-white bg-black px-6 py-1">Books</span>
            </h1>
        </div>

        <div class="text-center mt-10">
            <img src="/images/rory.jpg" alt="Rory" class="max-w-[50%] mx-auto">
        </div>

        <div class="bg-gray-50 rounded-[1.5rem] p-12 my-16 text-center border border-gray-100">
            <p class="text-3xl text-gray-600 font-light leading-relaxed">Reading is my way of figuring out how to be in the world.</p>
            <p class="text-2xl text-gray-400 mt-4">— Lorelai Leigh <span class="italic">Rory</span> Gilmore</p>
        </div>

        <section class="max-w-4xl mx-auto pb-24 text-center">
            <img src="/images/whywe1.webp" alt="bookshelf" class="max-w-[50%] mx-auto">

            <div class="text-4xl font-bold my-16">Why We Read?</div>

            <div class="flex flex-col md:flex-row items-center gap-10 mb-16 text-left">
                <div class="flex-1 flex justify-center">
                    <img src="/images/whywe2.jpg" alt="escape" class="max-w-[80%]">
                </div>
                <div class="flex-1 px-8">
                    <div class="flex items-center gap-4 mb-4">
                        <i class="pi pi-compass text-4xl text-gray-900"></i>
                        <h3 class="text-3xl font-bold text-gray-900">The Escape</h3>
                    </div>
                    <p class="text-gray-500 text-lg leading-relaxed max-w-[400px]">Travel to distant lands and different eras without ever leaving your favorite chair.</p>
                </div>
            </div>

            <div class="flex flex-col md:flex-row-reverse items-center gap-10 mb-16 text-left">
                <div class="flex-1 flex justify-center">
                    <img src="/images/whywe3.jpg" alt="connection" class="max-w-[80%]">
                </div>
                <div class="flex-1 px-8">
                    <div class="flex items-center gap-4 mb-4">
                        <i class="pi pi-heart text-4xl text-gray-900"></i>
                        <h3 class="text-3xl font-bold text-gray-900">The Connection</h3>
                    </div>
                    <p class="text-gray-500 text-lg leading-relaxed max-w-[400px]">Discover voices that echo your own heart and stories that broaden your world.</p>
                </div>
            </div>

            <div class="flex flex-col md:flex-row items-center gap-10 mb-16 text-left">
                <div class="flex-1 flex justify-center">
                    <img src="/images/whywe4.jpg" alt="stillness" class="max-w-[80%]">
                </div>
                <div class="flex-1 px-8">
                    <div class="flex items-center gap-4 mb-4">
                        <i class="pi pi-moon text-4xl text-gray-900"></i>
                        <h3 class="text-3xl font-bold text-gray-900">The Stillness</h3>
                    </div>
                    <p class="text-gray-500 text-lg leading-relaxed max-w-[400px]">In a fast-paced world, a book is an invitation to breathe, reflect, and just be.</p>
                </div>
            </div>

            <a href="/book/search" class="inline-block bg-gray-900 text-white px-10 py-4 rounded-full text-xl font-semibold hover:bg-black hover:-translate-y-1 transition duration-300">
                <i class="pi pi-book mr-2"></i> Browse Our Collection
            </a>
        </section>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>